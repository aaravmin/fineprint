# Clerk — copy to .env.local for development. Dev instance keys (pk_test_/sk_test_)
# work on localhost and Vercel previews, cap at 100 users, and show a
# "Development mode" banner on the auth UI.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard/portfolio
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/dashboard/portfolio

# Supabase — the browser talks to Postgres directly (RLS + Realtime); no API
# server exists. `npm run db:start` prints these. The browser gets the anon key
# only, never the service_role key.
NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Production (when a real domain lands — see docs/clerk-environments.md):
# never put pk_live_/sk_live_ in a committed file. They go in Vercel
# env vars, Production scope only.
