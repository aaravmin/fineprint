# --- Supabase (the entire backend) -------------------------------------------
# Local dev: `npm run db:start` prints these (API URL + anon + service_role).
# Hosted: Project Settings → API.
SUPABASE_URL=http://localhost:54321
SUPABASE_SERVICE_ROLE_KEY=

# The dashboard's copies (bundled into the browser — anon key only, never the
# service key). Put these in client/.env.local for Next.js to pick them up.
NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Clerk (dashboard sign-in) ------------------------------------------------
# https://dashboard.clerk.com → API keys. Also set your Clerk domain as
# third-party auth in Supabase when you need signed-in dashboard RLS locally.
# Local DB smoke tests keep that provider disabled so startup does not depend
# on a real Clerk app.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_DOMAIN=

# --- Agent drafting -----------------------------------------------------------
# Default is scripted (zero-LLM). Set USE_LLM=true plus an Anthropic key to
# let Claude write the drafts. https://console.anthropic.com/settings/keys
USE_LLM=false
ANTHROPIC_API_KEY=
# Optional model override for drafting (defaults to claude-haiku-4-5).
ANTHROPIC_MODEL=

# --- Worker fleet ---------------------------------------------------------------
# Display name for the dispatcher process; per-task agents name themselves.
WORKER_NAME=
# Restrict a dispatcher to task kinds, e.g. emissions_fine_analysis,benchmarking_filing
WORKER_KINDS=
# How many task agents one dispatcher runs at once (default 4).
AGENT_CONCURRENCY=

# --- NYC open data --------------------------------------------------------------
# LL84/DOB/HPD datasets on data.cityofnewyork.us. OPTIONAL: works without a
# token, but unauthenticated requests share a ~1000 req/hr pool; a free app
# token gets a dedicated allowance.
# Sign up: https://data.cityofnewyork.us/profile/edit/developer_settings
SOCRATA_APP_TOKEN=

# GeoSearch (address -> BBL) needs no key.
