# SpacetimeDB connection (local dev defaults)
SPACETIME_URI=ws://localhost:3000
DB_NAME=fineprint

# Vite client (must be prefixed VITE_)
VITE_SPACETIMEDB_HOST=ws://localhost:3000
VITE_SPACETIMEDB_DB_NAME=fineprint

# Agent drafting. Default is scripted (zero-LLM). Set USE_LLM=true plus one key to enable.
# Anthropic key: https://console.anthropic.com/settings/keys
# Gemini key:    https://aistudio.google.com/apikey
USE_LLM=false
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# Worker display name (each worker process registers under this name)
WORKER_NAME=

# NYC open data (LL84, DOB, HPD datasets on data.cityofnewyork.us).
# OPTIONAL: works without a token, but unauthenticated requests share a
# ~1000 req/hr pool; a free app token gets a dedicated allowance.
# Sign up: https://data.cityofnewyork.us/profile/edit/developer_settings
SOCRATA_APP_TOKEN=

# GeoSearch (address -> BBL) needs no key.
