# SpacetimeDB connection (local dev defaults)
SPACETIME_URI=ws://localhost:3011
DB_NAME=fineprint

# Vite client (must be prefixed VITE_)
VITE_SPACETIMEDB_HOST=ws://localhost:3011
VITE_SPACETIMEDB_DB_NAME=fineprint

# Agent drafting. Default is scripted (zero-LLM). Set USE_LLM=true plus one key to enable.
# Anthropic key: https://console.anthropic.com/settings/keys
# Gemini key:    https://aistudio.google.com/apikey
USE_LLM=false
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# Worker display name (each worker process registers under this name)
WORKER_NAME=

# NYC open data (LL84, DOB, HPD datasets on data.cityofnewyork.us).
# OPTIONAL: works without a token, but unauthenticated requests share a
# ~1000 req/hr pool; a free app token gets a dedicated allowance.
# Sign up: https://data.cityofnewyork.us/profile/edit/developer_settings
SOCRATA_APP_TOKEN=

# GeoSearch (address -> BBL) needs no key.

# --- Supabase (new backend; runs in parallel with SpacetimeDB during migration)
# Create a project at https://supabase.com/dashboard, then Project Settings ->
# API for the URL and the two keys. The service_role key is server-only — it
# bypasses row-level security, so never expose it to the browser or commit it.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# The project JWT secret (Project Settings -> API -> JWT Keys -> "JWT Secret",
# the legacy HS256 secret). The server signs a short-lived Supabase token from
# the Clerk session with this, so no Clerk<->Supabase dashboard integration is
# needed. Server-only; never expose it to the browser.
SUPABASE_JWT_SECRET=

# Which backend the dashboard reads and writes. `spacetime` (default) keeps the
# live app on SpacetimeDB; `supabase` switches to the Supabase + Trigger.dev
# path. Flip to `supabase` only after provisioning and running the migrations.
NEXT_PUBLIC_DATA_BACKEND=spacetime

# --- Trigger.dev (agent runs) ------------------------------------------------
# Create a project at https://cloud.trigger.dev. The project ref (proj_...) goes
# in agents/trigger.config.ts, or set it here for the CLI. TRIGGER_SECRET_KEY is
# read by the Next.js routes to trigger runs. The job's OWN secrets (SUPABASE_URL,
# SUPABASE_SERVICE_ROLE_KEY, ANTHROPIC_API_KEY, SOCRATA_APP_TOKEN) are set in the
# Trigger.dev dashboard under Environment Variables — see docs/migration-supabase-trigger.md.
TRIGGER_PROJECT_REF=
TRIGGER_SECRET_KEY=
