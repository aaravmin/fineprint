{
  "name": "fineprint",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "client",
    "agents",
    "engine",
    "data",
    "laws"
  ],
  "scripts": {
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "worker": "npm run worker --workspace agents",
    "fetch:remdb": "tsx data/scripts/fetch-remdb.ts",
    "extract:nyc-pdfs": "tsx data/scripts/extract-nyc-pdfs.ts",
    "parse:resstock": "tsx data/scripts/parse-resstock.ts",
    "merge:measures": "tsx data/scripts/merge-measures.ts",
    "find:overcap": "tsx data/scripts/find-overcap.ts",
    "audit:laws": "tsx scripts/audit-law-dashboard.ts",
    "audit:binder": "tsx scripts/audit-compliance-binder.ts",
    "dashboard": "npm run dev --workspace client",
    "worker:emissions": "WORKER_KINDS=emissions_fine_analysis,prescriptive_measures_plan npm run worker",
    "worker:filings": "WORKER_KINDS=benchmarking_filing,audit_filing,lighting_submetering_plan npm run worker",
    "worker:inspections": "WORKER_KINDS=facade_inspection,gas_piping_certification,mold_pest_remediation npm run worker",
    "db:start": "npx supabase start --exclude vector",
    "db:stop": "npx supabase stop",
    "db:reset": "npx supabase db reset",
    "db:smoke": "docker exec -i supabase_db_fineprint psql -U postgres -d postgres -v ON_ERROR_STOP=1 < scripts/db-smoke.sql",
    "ingest": "tsx scripts/ingest.ts"
  },
  "devDependencies": {
    "tsx": "^4.19.2",
    "@supabase/supabase-js": "^2.49.4",
    "prettier": "^3.4.2",
    "supabase": "^2.20.5"
  },
  "overrides": {
    "next": {
      "postcss": "8.5.16"
    }
  }
}
