{
  "name": "fineprint",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "spacetimedb",
    "client",
    "agents",
    "engine",
    "data"
  ],
  "scripts": {
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "publish:local": "spacetime publish --module-path spacetimedb --server local fineprint",
    "sync": "spacetime publish --module-path spacetimedb --server local fineprint -y && npm run generate",
    "generate": "spacetime generate --lang typescript --out-dir client/src/module_bindings --module-path spacetimedb && spacetime generate --lang typescript --out-dir agents/src/module_bindings --module-path spacetimedb",
    "worker": "npm run worker --workspace agents",
    "reviewer": "npm run reviewer --workspace agents",
    "dashboard": "npm run dev --workspace client",
    "worker:emissions": "WORKER_KINDS=emissions_fine_analysis,prescriptive_measures_plan npm run worker",
    "worker:filings": "WORKER_KINDS=benchmarking_filing,audit_filing,lighting_submetering_plan npm run worker",
    "worker:inspections": "WORKER_KINDS=facade_inspection,gas_piping_certification,mold_pest_remediation npm run worker"
  },
  "devDependencies": {
    "tsx": "^4.19.2"
  }
}
