# Google Places API key — enables specific building categorization
# (courthouse, hotel, school, named businesses) in data/src/category.ts.
#
# Optional: without it, categorization falls back to NYC PLUTO building-class
# and land-use data, which still classifies every NYC building offline.
#
# Setup:
#   1. cp data/.env.example data/.env
#   2. paste your key below
#   3. run with the env loaded, e.g.  node --env-file=data/.env <script>
#      (or export GOOGLE_PLACES_API_KEY in your shell)
#
# Get a key: https://console.cloud.google.com -> enable "Places API (New)".
GOOGLE_PLACES_API_KEY=
